# ============================================================
#  Famsops v2 — Docker Environment
#  Copy this to .env and edit before running ./start.sh
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=famsops
POSTGRES_USER=postgres
POSTGRES_PASSWORD=famsops_dev_pass      # CHANGE IN PRODUCTION
DB_PORT=5432                            # host-side port mapping

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=famsops-dev-jwt-secret-change-in-production-64chars
JWT_EXPIRES_IN=12h

# ── Ports ────────────────────────────────────────────────────
API_PORT=4000       # backend API port (host)
FRONTEND_PORT=80    # nginx / frontend port (host)

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production

# ── Seed ─────────────────────────────────────────────────────
# Set to true ONLY on first run to populate default users + sample data.
# Automatically set to false by start.sh after first seed.
SEED=false
