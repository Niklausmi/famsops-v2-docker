# ── Database ──────────────────────────────────────────────────
# Supabase Postgres (direct connection, bypasses their REST):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# Self-hosted Postgres:
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/famsops

# Set to 'true' if using Supabase or other cloud Postgres with SSL
DB_SSL=false

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-at-least-64-chars
JWT_EXPIRES_IN=12h

# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS — your frontend URL ──────────────────────────────────
FRONTEND_URL=http://localhost:5173
